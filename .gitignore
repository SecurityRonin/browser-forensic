/target
.worktrees

# cargo-fuzz build artifacts, corpora and crash reproducers (the targets and
# Cargo.toml are tracked; generated data is not).
/fuzz/target
/fuzz/corpus
/fuzz/artifacts
/fuzz/coverage
/fuzz/Cargo.lock

# Real browser session/history fixtures contain personal, proprietary on-disk
# data — never commit. Ignore EVERYTHING under the fixtures dir by default
# (secure-by-default: any file dropped here is uncommittable, not just the three
# known names); only the tracked placeholder is exempt. Repopulate locally with
# scripts/copy-fixtures.sh to run the real-bytes tests.
crates/snss-core/tests/fixtures/*
!crates/snss-core/tests/fixtures/.gitkeep

.DS_Store

# Agent worktrees / local session state
.claude/
